<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Passer une commande — Portail Crèches</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .commande-layout {
      display: grid;
      grid-template-columns: 1fr 300px;
      gap: 1.25rem;
      align-items: start;
    }
    .summary-panel {
      position: sticky;
      top: 70px;
    }
    .summary-item {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: .5rem;
      padding: .5rem 0;
      border-bottom: 1px solid var(--border);
      font-size: .875rem;
    }
    .summary-item:last-child { border-bottom: none; }
    .summary-item-name { flex: 1; min-width: 0; }
    .summary-item-name strong { display: block; color: var(--text); }
    .summary-item-name span { color: var(--text-muted); font-size: .8rem; }
    .summary-item-right { text-align: right; white-space: nowrap; flex-shrink: 0; }
    .summary-item-qty { color: var(--text-muted); font-size: .8rem; }
    .summary-item-subtotal { font-weight: 600; color: var(--text); }
    .summary-total-line {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-top: .75rem;
      margin-top: .25rem;
      border-top: 2px solid var(--border);
      font-size: 1rem;
    }
    .summary-empty {
      text-align: center;
      padding: 1.25rem 0;
      color: var(--text-muted);
      font-size: .875rem;
    }
    .summary-empty svg { display: block; margin: 0 auto .5rem; }
    @media (max-width: 860px) {
      .commande-layout {
        grid-template-columns: 1fr;
      }
      .summary-panel {
        position: static;
        order: -1;
      }
    }
  </style>
</head>
<body>
  <nav class="navbar">
    <div class="navbar-brand">
      <svg width="28" height="28" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="48" height="48" rx="8" fill="#1e3a5f"/>
        <path d="M24 10C16.27 10 10 16.27 10 24s6.27 14 14 14 14-6.27 14-14S31.73 10 24 10zm2 21h-4v-4h4v4zm0-8h-4V15h4v8z" fill="white"/>
      </svg>
      <span>Portail Crèches</span>
    </div>
    <div class="navbar-links">
      <span style="color:rgba(255,255,255,.7);font-size:.85rem;padding:.35rem .5rem"><%= crecheName %></span>
      <a href="/creche/deconnexion" class="nav-link">Déconnexion</a>
    </div>
  </nav>

  <main class="container">
    <% if (error) { %>
      <div class="alert alert-error">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
        <%= error %>
      </div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <%= success %>
      </div>
    <% } %>

    <div class="page-header">
      <div>
        <h1 class="page-title">Passer une commande</h1>
        <p class="page-subtitle">Sélectionnez les produits et les quantités souhaitées.</p>
      </div>
    </div>

    <% if (products.length === 0 && !error) { %>
      <div class="empty-state">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5">
          <path d="M20 7H4a2 2 0 00-2 2v6a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z"/>
          <path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/>
        </svg>
        <h2>Aucun produit disponible</h2>
        <p>Le catalogue produits est vide ou inaccessible.</p>
      </div>
    <% } else if (products.length > 0) { %>

    <form method="POST" action="/creche/commande" id="orderForm">
      <div class="commande-layout">

        <!-- LEFT: filter + product table -->
        <div>
          <div class="card" style="margin-bottom:1rem;padding:.75rem 1rem">
            <div style="display:flex;align-items:center;gap:.75rem">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--text-muted)" style="flex-shrink:0"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
              <input type="text" id="productFilter" class="form-input" placeholder="Filtrer par nom ou SKU..." style="margin:0" autocomplete="off">
              <span id="filterCount" style="font-size:.85rem;color:var(--text-muted);white-space:nowrap"><%= products.length %></span>
            </div>
          </div>

          <div class="card" style="padding:0;overflow:hidden">
            <div class="table-wrapper">
              <table class="orders-table">
                <thead>
                  <tr>
                    <th>Produit</th>
                    <th>Variante</th>
                    <th>SKU</th>
                    <th>Prix unit.</th>
                    <th style="width:110px">Quantité</th>
                  </tr>
                </thead>
                <tbody>
                  <% products.forEach(p => { %>
                  <tr class="order-row product-row" data-search="<%= (p.productTitle + ' ' + (p.variantTitle || '') + ' ' + p.sku).toLowerCase().replace(/"/g, '') %>">
                    <td><div class="product-name"><%= p.productTitle %></div></td>
                    <td class="text-muted"><% if (p.variantTitle) { %><%= p.variantTitle %><% } else { %>—<% } %></td>
                    <td class="text-muted sku-cell"><%= p.sku || '—' %></td>
                    <td class="price-cell"><strong><%= p.price %> EUR</strong></td>
                    <td>
                      <input type="hidden" name="ptitle[<%= p.variantId %>]" value="<%= p.productTitle %>">
                      <input type="hidden" name="pvtitle[<%= p.variantId %>]" value="<%= p.variantTitle || '' %>">
                      <input type="hidden" name="pprice[<%= p.variantId %>]" value="<%= p.price %>">
                      <input type="hidden" name="psku[<%= p.variantId %>]" value="<%= p.sku %>">
                      <input
                        type="number"
                        name="qty[<%= p.variantId %>]"
                        value="0"
                        min="0"
                        max="9999"
                        class="qty-input product-qty"
                        data-price="<%= p.price %>"
                        data-name="<%= p.productTitle %>"
                        data-variant="<%= p.variantTitle || '' %>"
                        data-id="<%= p.variantId %>"
                      >
                    </td>
                  </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- RIGHT: sticky summary panel -->
        <div class="summary-panel">
          <div class="card">
            <h2 class="card-title">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96C5 16.1 6.9 18 9 18h12v-2H9.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63H19c.75 0 1.41-.41 1.75-1.03l3.58-6.49A1 1 0 0023.46 5H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/></svg>
              Récapitulatif
            </h2>

            <!-- Empty state -->
            <div id="summaryEmpty" class="summary-empty">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#cbd5e1" stroke-width="1.5">
                <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 001.96-1.61L23 6H6"/>
              </svg>
              Aucun produit sélectionné
            </div>

            <!-- Filled state -->
            <div id="summaryFilled" style="display:none">
              <div id="summaryItemsList"></div>
              <div class="summary-total-line">
                <span style="font-weight:600;color:var(--text)">Total estimé</span>
                <strong style="font-size:1.15rem;color:var(--primary)" id="summaryTotal">0.00 EUR</strong>
              </div>
            </div>

            <div style="margin-top:1.25rem;padding-top:1.25rem;border-top:1px solid var(--border)">
              <button type="submit" class="btn btn-approve btn-full" id="submitBtn" disabled>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
                Envoyer à l'enseigne
              </button>
            </div>
          </div>
        </div>

      </div><!-- /.commande-layout -->
    </form>

    <% } %>
  </main>

  <script>
    const filterInput  = document.getElementById('productFilter');
    const filterCount  = document.getElementById('filterCount');
    const submitBtn    = document.getElementById('submitBtn');
    const summaryEmpty  = document.getElementById('summaryEmpty');
    const summaryFilled = document.getElementById('summaryFilled');
    const summaryList   = document.getElementById('summaryItemsList');
    const summaryTotal  = document.getElementById('summaryTotal');
    const rows = Array.from(document.querySelectorAll('.product-row'));

    // --- Filter ---
    if (filterInput) {
      filterInput.addEventListener('input', () => {
        const q = filterInput.value.toLowerCase();
        let visible = 0;
        rows.forEach(row => {
          const match = !q || row.dataset.search.includes(q);
          row.style.display = match ? '' : 'none';
          if (match) visible++;
        });
        if (filterCount) filterCount.textContent = visible;
      });
    }

    // --- Live summary ---
    function escHtml(s) {
      return String(s || '')
        .replace(/&/g,'&amp;').replace(/</g,'&lt;')
        .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function updateSummary() {
      const selected = [];
      let total = 0;

      document.querySelectorAll('.product-qty').forEach(input => {
        const qty = parseInt(input.value) || 0;
        if (qty > 0) {
          const price    = parseFloat(input.dataset.price);
          const subtotal = price * qty;
          total += subtotal;
          selected.push({
            name:     input.dataset.name,
            variant:  input.dataset.variant,
            price,
            qty,
            subtotal,
          });
        }
      });

      if (selected.length === 0) {
        summaryEmpty.style.display  = '';
        summaryFilled.style.display = 'none';
        submitBtn.disabled = true;
        return;
      }

      summaryEmpty.style.display  = 'none';
      summaryFilled.style.display = '';
      submitBtn.disabled = false;

      summaryList.innerHTML = selected.map(item => `
        <div class="summary-item">
          <div class="summary-item-name">
            <strong>${escHtml(item.name)}</strong>
            ${item.variant ? `<span>${escHtml(item.variant)}</span>` : ''}
          </div>
          <div class="summary-item-right">
            <div class="summary-item-qty">${item.qty} × ${item.price.toFixed(2)}</div>
            <div class="summary-item-subtotal">${item.subtotal.toFixed(2)} EUR</div>
          </div>
        </div>
      `).join('');

      summaryTotal.textContent = total.toFixed(2) + ' EUR';
    }

    document.querySelectorAll('.product-qty').forEach(input => {
      input.addEventListener('input', updateSummary);
    });

    // --- Confirm on submit ---
    document.getElementById('orderForm').addEventListener('submit', e => {
      const hasItems = Array.from(document.querySelectorAll('.product-qty'))
        .some(i => (parseInt(i.value) || 0) > 0);
      if (!hasItems) { e.preventDefault(); return; }
      if (!confirm('Confirmer l\'envoi de la commande à l\'enseigne ?')) e.preventDefault();
    });
  </script>
</body>
</html>

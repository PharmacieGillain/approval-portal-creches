<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Historique — Portail Mutterfirma</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="navbar-brand">
      <svg width="28" height="28" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="48" height="48" rx="8" fill="#1e3a5f"/>
        <path d="M24 10C16.27 10 10 16.27 10 24s6.27 14 14 14 14-6.27 14-14S31.73 10 24 10zm2 21h-4v-4h4v4zm0-8h-4V15h4v8z" fill="white"/>
      </svg>
      <span>Portail Mutterfirma</span>
    </div>
    <div class="navbar-links">
      <a href="/tableau-de-bord" class="nav-link">Tableau de bord</a>
      <a href="/historique" class="nav-link nav-link-active">Historique</a>
      <a href="/deconnexion" class="nav-link">Déconnexion</a>
    </div>
  </nav>

  <main class="container">
    <% if (error) { %>
      <div class="alert alert-error">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
        <%= error %>
      </div>
    <% } %>

    <div class="page-header">
      <div>
        <h1 class="page-title">Historique des commandes</h1>
        <p class="page-subtitle">Toutes les commandes crèches et foyers, triées par date</p>
      </div>
      <div class="stats-badge">
        <span class="stats-number"><%= orders.length %></span>
        <span class="stats-label">commande(s)</span>
      </div>
    </div>

    <% if (orders.length === 0) { %>
      <div class="empty-state">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5">
          <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
        <h2>Aucune commande dans l'historique</h2>
        <p>Les commandes traitées apparaîtront ici.</p>
      </div>
    <% } else { %>
      <div class="card">
        <table class="orders-table">
          <thead>
            <tr>
              <th>Commande</th>
              <th>Date</th>
              <th>Établissement</th>
              <th>Client</th>
              <th>Produits</th>
              <th>Total</th>
              <th>Statut</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% orders.forEach(order => {
              const company = getCompanyName(order);
              const customer = getCustomerName(order);
              const status = getOrderStatus(order);
            %>
            <tr class="order-row">
              <td>
                <span class="order-number">#<%= order.order_number %></span>
              </td>
              <td class="text-muted">
                <%= formatDate(order.created_at) %>
              </td>
              <td>
                <% if (company) { %>
                  <strong class="company-name"><%= company %></strong>
                <% } else { %>
                  <span class="text-muted">—</span>
                <% } %>
              </td>
              <td><%= customer %></td>
              <td class="products-cell">
                <% const productSummary = order.line_items.slice(0, 3).map(item =>
                  `${item.title}${item.variant_title && item.variant_title !== 'Default Title' ? ' — ' + item.variant_title : ''} ×${item.quantity}`
                ); %>
                <% productSummary.forEach(p => { %>
                  <div class="product-line"><%= p %></div>
                <% }); %>
                <% if (order.line_items.length > 3) { %>
                  <div class="product-more">+ <%= order.line_items.length - 3 %> autre(s)</div>
                <% } %>
              </td>
              <td class="price-cell">
                <strong><%= parseFloat(order.total_price).toFixed(2) %> <%= order.currency %></strong>
              </td>
              <td>
                <% if (status === 'validé') { %>
                  <span class="badge badge-success">Validé</span>
                <% } else if (status === 'refusé') { %>
                  <span class="badge badge-danger">Refusé</span>
                <% } else if (status === 'en-attente-validation') { %>
                  <span class="badge badge-pending">En attente</span>
                <% } else { %>
                  <span class="badge badge-neutral">—</span>
                <% } %>
              </td>
              <td>
                <a href="/commandes/<%= order.id %>" class="btn btn-sm btn-secondary">
                  Voir
                </a>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } %>
  </main>
</body>
</html>

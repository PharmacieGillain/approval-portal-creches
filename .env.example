# ============================================================
# Portail Approbation Crèches — Variables d'environnement
# ============================================================
# Copiez ce fichier en .env et remplissez les valeurs

# --- Shopify ---
# Nom de la boutique (ex: mapharmacie.myshopify.com)
SHOPIFY_SHOP=mapharmacie.myshopify.com

# Identifiants API Shopify pour l'authentification Basic Auth
# Disponibles dans : Shopify Admin → Applications → Développer des applications → Identifiants API
# Permissions requises : read_orders, write_orders, read_products
SHOPIFY_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Authentification du portail ---
# Mot de passe unique pour accéder au portail
PORTAL_PASSWORD=motdepassesecret

# Clé secrète pour les sessions Express (chaîne aléatoire longue)
SESSION_SECRET=changez-moi-avec-une-longue-chaine-aleatoire-et-secrete

# --- Notifications email (optionnel) ---
# Si SMTP_HOST n'est pas défini, les notifications email sont désactivées

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notifications@example.com
SMTP_PASS=motdepasse_smtp
SMTP_FROM="Portail Crèches <notifications@example.com>"
NOTIFICATION_EMAIL=responsable@enseigne.com

# --- Base de données ---
# Chaîne de connexion PostgreSQL (obligatoire). Sur Render, ajoutez une base
# PostgreSQL (plan gratuit) puis copiez son "Internal Database URL" ici.
# Voir SETUP.md pour les instructions détaillées.
# Format local : postgres://user:password@localhost:5432/nom_de_la_base
DATABASE_URL=postgres://user:password@localhost:5432/approval_portal_creches

# --- Serveur ---
PORT=3000
